  @@index([credit_score(sort: Desc)], map: "idx_tender_classifications_credit_score")
  @@index([primary_domain], map: "idx_tender_classifications_domain")
  @@index([esg_score(sort: Desc)], map: "idx_tender_classifications_esg_score")
  @@index([tender_id], map: "idx_tender_classifications_tender")
}

