# Portal_v3 environment example
# Dummy values only. Do not paste production secrets into this file.

# Required - ESG PostgreSQL connection used by the app runtime.
ESG_DATABASE_URL=postgresql://esg_user:esg_password@esg-db.example.com:5432/esg_portal

# Required - Credit PostgreSQL connection used by the app runtime.
CREDIT_DATABASE_URL=postgresql://credit_user:credit_password@credit-db.example.com:5432/credit_portal

# Optional - Prisma CLI datasource name used by schema.prisma; prefer setting this per command.
DATABASE_URL=postgresql://user:password@localhost:5432/portal_dev

# Required - Secret used by NextAuth to sign JWT sessions.
NEXTAUTH_SECRET=replace-with-a-long-random-string

# Optional - Public app URL; app scheduler/config falls back to http://localhost:3000.
NEXTAUTH_URL=http://localhost:3000

# Optional - Base URL for server-rendered tender API fetches; falls back to http://localhost:3000.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Optional - Next.js runtime marker, normally set by Next.js; leave unset in normal env files.
NEXT_RUNTIME=

# Optional - Next.js phase marker, normally set by Next.js; leave unset in normal env files.
NEXT_PHASE=

# Optional - Set to true to start the in-process alert scheduler from instrumentation.
ENABLE_ALERT_SCHEDULER=false

# Required for cron routes - Bearer secret used by scheduled alert endpoints.
CRON_SECRET=replace-with-cron-shared-secret

# Required for OpenAI features - Article assistant, PDFX translation, tenders, digests, and ESG drivers.
OPENAI_API_KEY=sk-project-dummy-openai-key

# Optional - OpenAI organization id for PDFX translation client.
OPENAI_ORG_ID=org_dummy

# Optional - ESG driver model; defaults to gpt-5-mini.
OPENAI_ESG_DRIVERS_MODEL=gpt-5-mini

# Required for ESG driver generation - Google Custom Search API key.
GOOGLE_API_KEY_2=dummy-google-custom-search-key

# Required for ESG driver generation - Google Custom Search engine id.
GOOGLE_CSE_ID_2=dummy-google-cse-id

# Optional - Enables Tavily-backed web search inside the article assistant.
TAVILY_API_KEY=tvly-dummy-key

# Optional - Bearer token for S&P Global search requests.
SPGLOBAL_SEARCH_TOKEN=dummy-spglobal-token

# Optional - Custom AI summarizer endpoint; empty disables this integration.
CUSTOM_AI_URL=https://ai.example.com/summarize

# Optional - Custom AI summarizer bearer token; empty disables this integration.
CUSTOM_AI_KEY=dummy-custom-ai-key

# Required for standalone Deep Agent - Ollama cloud/API key.
OLLAMA_API_KEY=dummy-ollama-key

# Optional - Ollama host; defaults to https://ollama.com.
OLLAMA_HOST=https://ollama.com

# Optional - Ollama model; defaults to minimax-m2.5:cloud.
OLLAMA_MODEL=minimax-m2.5:cloud

# Optional - PDFX storage directory; defaults to .pdfx_store.
PDFX_STORAGE_DIR=.pdfx_store

# Required for queued alert email sending - SMTP username.
MAIL_USERNAME=alerts@example.com

# Required for queued alert email sending - SMTP password or app password.
MAIL_PASSWORD=dummy-mail-password

# Optional - SMTP host for queued alert email; defaults to smtp.gmail.com.
MAIL_SERVER=smtp.gmail.com

# Optional - SMTP port for queued alert email; defaults to 587.
MAIL_PORT=587

# Optional - Sender address for queued alert email; falls back to MAIL_USERNAME.
MAIL_FROM=alerts@example.com

# Required for manual admin email sending - Gmail/SMTP username for that route.
EMAIL_USER=alerts@example.com

# Required for manual admin email sending - Gmail/SMTP password for that route.
EMAIL_PASS=dummy-email-password
